  "scripts": {
    "start": "cp ./src/locales/ru.json ./public/ru_dev.json && cp ./src/locales/en.json ./public/en_dev.json && cp ./src/locales/de.json ./public/de_dev.json && cp ./src/locales/tr.json ./public/tr_dev.json && cp ./src/locales/zh.json ./public/zh_dev.json && craco start",
    "build": "GENERATE_SOURCEMAP=false craco build && cp ./src/locales/ru.json ./build/ru_$(grep REACT_APP_LOCALIZATION_VERSION ./.env | cut -d '=' -f 2-).json && cp ./src/locales/en.json ./build/en_$(grep REACT_APP_LOCALIZATION_VERSION ./.env | cut -d '=' -f 2-).json && cp ./src/locales/de.json ./build/de_$(grep REACT_APP_LOCALIZATION_VERSION ./.env | cut -d '=' -f 2-).json && cp ./src/locales/tr.json ./build/tr_$(grep REACT_APP_LOCALIZATION_VERSION ./.env | cut -d '=' -f 2-).json && cp ./src/locales/zh.json ./build/zh_$(grep REACT_APP_LOCALIZATION_VERSION ./.env | cut -d '=' -f 2-).json",
    "test": "craco test",
    "eject": "craco eject",
    "analyze": "cra-bundle-analyzer"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^6.4.5",
    "cra-bundle-analyzer": "^0.1.0",
    "prop-types": "^15.7.2"
  }
